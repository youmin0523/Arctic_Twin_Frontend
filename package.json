{
  "name": "digital-twin-client",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "copy:simulations": "node -e \"const fs=require('fs'),p=require('path');const s=p.resolve('../backend/data/simulations'),d=p.resolve('public/simulations');fs.mkdirSync(d,{recursive:true});for(const f of fs.readdirSync(s))if(f.endsWith('.json'))fs.copyFileSync(p.join(s,f),p.join(d,f));console.log('copied simulations');\""
  },
  "dependencies": {
    "@deck.gl/core": "^8.9.35",
    "@deck.gl/geo-layers": "^8.9.35",
    "@deck.gl/layers": "^8.9.35",
    "@deck.gl/react": "^8.9.35",
    "cesium": "^1.116.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "searoute-js": "^0.1.0",
    "three": "^0.160.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.2.1",
    "vite": "^5.2.0",
    "vite-plugin-cesium": "^1.2.22"
  }
}
